<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.conk.member.query.infrastructure.mapper.SellerQueryMapper">
    <resultMap id="sellerListItemMap" type="com.conk.member.query.dto.mapper.SellerListItem">
        <id property="id" column="seller_id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="customerCode" column="customer_code"/>
        <result property="sellerInfo" column="seller_info"/>
        <result property="brandNameKo" column="brand_name_ko"/>
        <result property="brandNameEn" column="brand_name_en"/>
        <result property="representativeName" column="representative_name"/>
        <result property="phoneNo" column="phone_no"/>
        <result property="email" column="email"/>
        <result property="categoryName" column="category_name"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    <select id="findSellers" parameterType="com.conk.member.query.dto.condition.SellerSearchCondition" resultMap="sellerListItemMap">
        SELECT s.seller_id, s.tenant_id, s.customer_code, s.seller_info, s.brand_name_ko,
               s.brand_name_en, s.representative_name, s.phone_no, s.email,
               s.category_name, s.status, s.created_at
        FROM seller s
        <where>
            <if test="tenantId != null and tenantId != ''">AND s.tenant_id = #{tenantId}</if>
            <if test="status != null and status != ''">AND s.status = #{status}</if>
            <if test="keyword != null and keyword != ''">
                AND (s.brand_name_ko LIKE CONCAT('%', #{keyword}, '%')
                     OR s.brand_name_en LIKE CONCAT('%', #{keyword}, '%')
                     OR s.representative_name LIKE CONCAT('%', #{keyword}, '%')
                     OR s.customer_code LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY s.created_at DESC, s.seller_id ASC
    </select>
</mapper>
