<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.conk.member.query.infrastructure.mapper.MemberUserQueryMapper">
    <resultMap id="userListItemMap" type="com.conk.member.query.dto.mapper.UserListItem">
        <id property="id" column="account_id"/>
        <result property="name" column="account_name"/>
        <result property="email" column="email"/>
        <result property="role" column="role_name"/>
        <result property="accountStatus" column="account_status"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="sellerId" column="seller_id"/>
        <result property="warehouseId" column="warehouse_id"/>
        <result property="workerCode" column="worker_code"/>
        <result property="lastLoginAt" column="last_login_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    <select id="findUsers" parameterType="com.conk.member.query.dto.condition.UserSearchCondition" resultMap="userListItemMap">
        SELECT a.account_id, a.account_name, a.email, r.role_name, a.account_status,
               a.tenant_id, a.seller_id, a.warehouse_id, a.worker_code,
               a.last_login_at, a.created_at
        FROM account a
        JOIN role r ON r.role_id = a.role_id
        <where>
            <if test="tenantId != null and tenantId != ''">AND a.tenant_id = #{tenantId}</if>
            <if test="roleName != null and roleName != ''">AND r.role_name = #{roleName}</if>
            <if test="accountStatus != null and accountStatus != ''">AND a.account_status = #{accountStatus}</if>
            <if test="sellerId != null and sellerId != ''">AND a.seller_id = #{sellerId}</if>
            <if test="warehouseId != null and warehouseId != ''">AND a.warehouse_id = #{warehouseId}</if>
            <if test="keyword != null and keyword != ''">
                AND (a.account_name LIKE CONCAT('%', #{keyword}, '%')
                     OR a.email LIKE CONCAT('%', #{keyword}, '%')
                     OR a.worker_code LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY a.created_at DESC, a.account_id ASC
    </select>
</mapper>
