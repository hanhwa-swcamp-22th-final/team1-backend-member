<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.conk.member.query.infrastructure.mapper.CompanyQueryMapper">
    <resultMap id="companyListItemMap" type="com.conk.member.query.dto.mapper.CompanyListItem">
        <id property="id" column="tenant_id"/>
        <result property="name" column="tenant_name"/>
        <result property="tenantCode" column="tenant_code"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="representative" column="representative_name"/>
        <result property="businessNumber" column="business_no"/>
        <result property="phone" column="phone_no"/>
        <result property="email" column="email"/>
        <result property="address" column="address"/>
        <result property="companyType" column="tenant_type"/>
        <result property="warehouseCount" column="warehouse_count"/>
        <result property="sellerCount" column="seller_count"/>
        <result property="userCount" column="user_count"/>
    </resultMap>
    <select id="findCompanies" parameterType="com.conk.member.query.dto.condition.CompanySearchCondition" resultMap="companyListItemMap">
        SELECT t.tenant_id, t.tenant_name, t.tenant_code, t.status, t.created_at,
               t.representative_name, t.business_no, t.phone_no, t.email,
               t.address, t.tenant_type,
               0 AS warehouse_count,
               (SELECT COUNT(1) FROM seller s WHERE s.tenant_id = t.tenant_id) AS seller_count,
               (SELECT COUNT(1) FROM account a WHERE a.tenant_id = t.tenant_id) AS user_count
        FROM tenant t
        <where>
            <if test="status != null and status != ''">AND t.status = #{status}</if>
            <if test="keyword != null and keyword != ''">
                AND (t.tenant_name LIKE CONCAT('%', #{keyword}, '%')
                     OR t.tenant_code LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY t.created_at DESC, t.tenant_id ASC
    </select>
</mapper>
